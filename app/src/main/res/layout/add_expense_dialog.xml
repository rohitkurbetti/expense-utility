<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/spinnerOptionsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/monthlyCardView">

        <CheckBox
            android:id="@+id/homeCheckBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home" />

        <!-- Spinner -->
        <Spinner
            android:id="@+id/spinnerOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:entries="@array/expense_categories"
            android:gravity="center_vertical"
            android:importantForAccessibility="yes"
            android:minHeight="48dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/monthlyCardView" />

    </LinearLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/et_particularsM"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:hint="Enter expense here"
        app:endIconDrawable="@drawable/close_circle_svgrepo_com__1_"
        app:endIconMode="clear_text"
        app:layout_constraintTop_toBottomOf="@+id/spinnerOptionsLayout">

        <AutoCompleteTextView
            android:id="@+id/et_particulars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLength="15"
            android:paddingHorizontal="15dp"
            android:paddingVertical="15dp" />
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/et_part_detailsM"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:hint="Enter description"
        app:endIconDrawable="@drawable/close_circle_svgrepo_com__1_"
        app:endIconMode="clear_text"
        app:layout_constraintTop_toBottomOf="@+id/et_particularsM">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_part_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="20"
            android:minLines="3"
            android:paddingHorizontal="10dp"
            android:paddingVertical="15dp"
            android:singleLine="false" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/amountDateLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/et_part_detailsM">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/et_amountM"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:layout_weight=".5"
            android:hint="Enter amount"
            app:endIconDrawable="@drawable/close_circle_svgrepo_com__1_"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="15dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/et_date_timeM"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="20dp"
            android:layout_weight=".5"
            android:hint="Date and Time"
            app:endIconDrawable="@drawable/close_circle_svgrepo_com__1_"
            app:endIconMode="clear_text"
            app:layout_constraintTop_toBottomOf="@+id/et_amountM">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_date_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:focusable="false"
                android:inputType="none"
                android:paddingHorizontal="10dp"
                android:paddingVertical="15dp" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>


</LinearLayout>