<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView
        android:id="@+id/expenseIdTxt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:gravity="center"
        android:text="ID"
        android:visibility="gone" />

    <!-- Circular background with initials -->
    <TextView
        android:id="@+id/textInitials"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/circle_bg"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/expenseParticularsTxt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_weight="1"
        android:gravity="start"
        android:text="Particulars"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/capsuleLayout"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/capsule_bg"
        android:gravity="center_vertical"
        android:minWidth="50dp"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <ImageView
            android:id="@+id/iconView"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/home_svgrepo_com__1_"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxWidth="120dp"
            android:singleLine="true"
            android:text="Home"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/expenseAmountTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:gravity="end"
        android:minWidth="50dp"
        android:singleLine="true"
        android:text="Amount"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/expenseDateTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:gravity="center"
        android:minWidth="40dp"
        android:singleLine="true"
        android:text="Date"
        android:textSize="12sp" />

    <ImageView
        android:id="@+id/expenseDeleteBtn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="6dp"
        android:src="@drawable/delete_svgrepo_com" />
</LinearLayout>